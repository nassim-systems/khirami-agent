{
  "version": 2,
  "env": {
    "AUTH_TOKEN": "@auth_token",
    "OPENAI_API_KEY": "@openai_api_key",
    "ANTHROPIC_API_KEY": "@anthropic_api_key"
  },
  "builds": [
    { "src": "api/ask.js", "use": "@vercel/node" },
    { "src": "public/widget.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/ask", "dest": "/api/ask.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
